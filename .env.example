# ═════════════════════════════════════════════════════════════════════════════
# BACKEND ENVIRONMENT — repensar-multiplatform-backend/.env
# Copy this file to .env and fill in your values.
# .env is never committed to git.
# ═════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────────────────
# Full PostgreSQL connection string used by SQLModel / SQLAlchemy.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://repensar:repensar_password@localhost:5432/repensar_db

# Individual connection parameters (used by some tooling / Alembic fallback).
DB_HOST=localhost
DB_PORT=5432
DB_USER=repensar
DB_PASSWORD=repensar_password
DB_NAME=repensar_db

# ─────────────────────────────────────────────────────────────────────────────
# SECURITY & TOKENS
# ─────────────────────────────────────────────────────────────────────────────
# SECRET_KEY — used to sign JWT tokens. MUST be changed in production.
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-in-production

# How long access tokens remain valid (minutes). Default: 30 min.
ACCESS_TOKEN_EXPIRE_MINUTES=30

# How long refresh tokens remain valid (days). Default: 30 days.
REFRESH_TOKEN_EXPIRE_DAYS=30

# Brute-force protection: lock an account after this many failed logins.
MAX_LOGIN_ATTEMPTS=5

# How long (minutes) a locked account stays locked before auto-unlocking.
LOCKOUT_DURATION_MINUTES=30

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL (SMTP)
# ─────────────────────────────────────────────────────────────────────────────
# Leave ALL SMTP variables empty to disable email sending entirely.
# When disabled, emails are logged to stdout instead of delivered.
# Required for: email verification, password reset, notifications.
#
# For Gmail:
#   1. Enable 2-Factor Authentication on your Google account.
#   2. Go to https://myaccount.google.com/apppasswords and generate an App Password.
#   3. Use that App Password as SMTP_PASSWORD (not your regular Google password).
#
# For other providers:
#   SendGrid:  smtp.sendgrid.net  port 587
#   Mailgun:   smtp.mailgun.org   port 587
#   AWS SES:   email-smtp.<region>.amazonaws.com  port 587
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_FROM_NAME=Repensar
ADMIN_NOTIFICATION_EMAIL=your-email@gmail.com

# ─────────────────────────────────────────────────────────────────────────────
# APPLICATION URLS
# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND_URL — used for CORS and building links inside emails (e.g. email
# verification links). Must match the URL the browser uses to reach Next.js.
#
# Local (same machine):          http://localhost:3000
# LAN access (other devices):    http://192.168.1.5:3000
# Production:                    https://app.repensar.org
#
FRONTEND_URL=http://localhost:3000

# BACKEND_URL — the public URL of this FastAPI process. Used in OAuth redirect
# URIs and any backend-generated links that point back to the API.
# If the backend is behind the Next.js proxy, this can stay as localhost.
BACKEND_URL=http://localhost:8000

# CORS_ORIGINS — JSON array of origins the browser is allowed to call the
# backend from directly. Even with the Next.js proxy, the browser may still
# make direct calls in some edge cases (e.g. SSE streams, file downloads).
#
# Add every origin (hostname + port) a browser might use:
#   - http://localhost:3000   (dev, same machine)
#   - http://192.168.1.5:3000 (dev, LAN access from another device)
#   - https://app.example.com (production)
#
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001", "http://127.0.0.1:3000"]

# ─────────────────────────────────────────────────────────────────────────────
# GOOGLE OAUTH (optional)
# ─────────────────────────────────────────────────────────────────────────────
# Leave all three variables empty to disable Google Sign-In entirely.
# The button will be hidden from the login/register pages automatically.
#
# Setup:
#   1. Go to https://console.cloud.google.com/ and create a project.
#   2. Enable the Google Identity / OAuth 2.0 API.
#   3. Create OAuth 2.0 credentials → Web application.
#   4. Add your redirect URI to "Authorized redirect URIs" (see below).
#   5. Copy the Client ID and Client Secret here.
#
# GOOGLE_REDIRECT_URI must point to the BACKEND /auth/google/callback endpoint,
# reachable by Google's servers (not the browser). In local dev this is
# usually http://localhost:8000/auth/google/callback. In production, use
# your public backend URL or expose the route through the Next.js proxy:
# http://your-domain.com/auth/google/callback
#
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ─────────────────────────────────────────────────────────────────────────────
# FILE STORAGE
# ─────────────────────────────────────────────────────────────────────────────
# STORAGE_BACKEND — where uploaded files are saved.
#   "local"  — saved to UPLOAD_DIR on this machine (served at /uploads/*).
#   "s3"     — saved to AWS S3 (requires S3_* variables below).
STORAGE_BACKEND=local

# UPLOAD_DIR — local filesystem path for file uploads (only used when
# STORAGE_BACKEND=local). Path is relative to the backend root directory.
UPLOAD_DIR=./uploads

# MAX_FILE_SIZE — maximum upload size in bytes. Default: 10 MB.
MAX_FILE_SIZE=10485760

# S3 configuration (only required when STORAGE_BACKEND=s3):
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# ─────────────────────────────────────────────────────────────────────────────
# REDIS (optional)
# ─────────────────────────────────────────────────────────────────────────────
# Used for: token blacklisting (logout-all-devices), distributed rate limiting.
# If not set, the backend falls back to in-memory storage (single-process only,
# not suitable for multi-worker production deployments).
#
# REDIS_URL=redis://localhost:6379/0

# ─────────────────────────────────────────────────────────────────────────────
# DEVELOPMENT FLAGS
# ─────────────────────────────────────────────────────────────────────────────
# DEBUG — enables verbose logging and FastAPI's /docs + /redoc endpoints.
# Set to false in production.
DEBUG=true

# DISABLE_RATE_LIMITING — bypasses all IP-based rate limits.
# Useful in development and automated tests. NEVER enable in production.
DISABLE_RATE_LIMITING=true

# ─── PRODUCTION overrides ────────────────────────────────────────────────────
# Uncomment and set these when deploying to production:
#
# DEBUG=false
# DISABLE_RATE_LIMITING=false
# SECRET_KEY=<long-random-string>
# STORAGE_BACKEND=s3
# REDIS_URL=redis://your-redis-host:6379/0
# FRONTEND_URL=https://app.repensar.org
# CORS_ORIGINS=["https://app.repensar.org"]
