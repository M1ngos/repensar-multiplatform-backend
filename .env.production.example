# ═════════════════════════════════════════════════════════════════════════════
# BACKEND ENVIRONMENT — Railway production
# Reference this file when setting environment variables in Railway's dashboard.
# Variable Reference syntax in Railway: ${{Postgres.DATABASE_URL}}
#
# Sections:
#   1.  Security & JWT
#   2.  Database
#   3.  Redis
#   4.  Email (SMTP)
#   5.  Application URLs & CORS
#   6.  Newsletter
#   7.  Google OAuth
#   8.  Rate Limiting & Brute-Force Protection
#   9.  File Storage
#   10. Production Flags
# ═════════════════════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────────────────────
# 1. SECURITY & JWT
# ─────────────────────────────────────────────────────────────────────────────

# SECRET_KEY — [REQUIRED]
#   Signs and verifies all JWT access tokens and refresh tokens.
#   The default value in config.py is publicly known and MUST be replaced.
#   Any change invalidates all existing sessions (users must log in again).
#
#   Generate a secure key:
#     python -c "import secrets; print(secrets.token_hex(32))"
#
SECRET_KEY=replace-this-with-a-64-character-hex-string-generated-as-shown-above

# ALGORITHM — [Optional, default: HS256]
#   JWT signing algorithm. HS256 is correct for symmetric secret keys.
#   Only change if you switch to RS256 with asymmetric keys.
#
# ALGORITHM=HS256

# ACCESS_TOKEN_EXPIRE_MINUTES — [Optional, default: 30]
#   How long an access token is valid. Shorter = more secure but more re-logins.
#
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# REFRESH_TOKEN_EXPIRE_DAYS — [Optional, default: 30]
#   How long a refresh token is valid. Token family rotation is enabled;
#   a stolen refresh token will invalidate the entire family on next use.
#
# REFRESH_TOKEN_EXPIRE_DAYS=30


# ─────────────────────────────────────────────────────────────────────────────
# 2. DATABASE
# ─────────────────────────────────────────────────────────────────────────────

# DATABASE_URL — [REQUIRED]
#   Full PostgreSQL connection string used by SQLModel / SQLAlchemy and Alembic.
#   When using Railway's PostgreSQL plugin, use the Variable Reference below
#   so Railway injects the correct internal URL automatically. The plugin
#   sets the DATABASE_URL variable on the Postgres service; reference it here.
#
#   Railway Variable Reference (copy exactly — Railway resolves it at runtime):
DATABASE_URL=${{Postgres.DATABASE_URL}}

# Individual DB parameters — [Optional]
#   Only used if DATABASE_URL is not set (fallback for tooling that reads
#   individual vars). With Railway's plugin, DATABASE_URL takes precedence
#   and these can be omitted.
#
# DB_HOST=
# DB_PORT=5432
# DB_USER=
# DB_PASSWORD=
# DB_NAME=


# ─────────────────────────────────────────────────────────────────────────────
# 3. REDIS
# ─────────────────────────────────────────────────────────────────────────────

# REDIS_URL — [Optional, strongly recommended for production]
#   Used for:
#     • Token blacklisting (logout-all-devices / revoke-all-sessions)
#     • Distributed rate limiting across multiple workers
#   If not set, falls back to in-memory storage — not suitable for
#   multi-worker deployments or crash-safe session revocation.
#
#   With Railway's Redis plugin, use the Variable Reference:
# REDIS_URL=${{Redis.REDIS_URL}}


# ─────────────────────────────────────────────────────────────────────────────
# 4. EMAIL (SMTP)
# ─────────────────────────────────────────────────────────────────────────────
#
# All SMTP variables are optional. If SMTP_HOST is not set, emails are
# logged to stdout instead of delivered (useful for debugging, bad for users).
# Required for: account verification, password reset, admin notifications,
# newsletter campaigns.
#
# Recommended providers for transactional email:
#   SendGrid:  smtp.sendgrid.net   port 587  (use API key as SMTP_PASSWORD)
#   Mailgun:   smtp.mailgun.org    port 587
#   AWS SES:   email-smtp.<region>.amazonaws.com  port 587
#   Postmark:  smtp.postmarkapp.com port 587

# SMTP_HOST — [Optional]
SMTP_HOST=smtp.sendgrid.net

# SMTP_PORT — [Optional, default: 587]
SMTP_PORT=587

# SMTP_USERNAME — [Optional]
#   For SendGrid: use the literal string "apikey"
#   For others:   your SMTP username / email address
SMTP_USERNAME=apikey

# SMTP_PASSWORD — [Optional]
#   For SendGrid: your SendGrid API key (starts with SG.)
#   For Gmail:    an App Password (not your account password)
SMTP_PASSWORD=SG.your-sendgrid-api-key

# EMAIL_FROM — [Optional]
#   The "From" address for all transactional emails.
#   Must be a verified sender in your email provider.
EMAIL_FROM=no-reply@your-domain.com

# EMAIL_FROM_NAME — [Optional, default: "Repensar"]
EMAIL_FROM_NAME=Repensar

# ADMIN_NOTIFICATION_EMAIL — [Optional]
#   Receives contact form submissions and other admin notifications.
#   Falls back to EMAIL_FROM if not set.
ADMIN_NOTIFICATION_EMAIL=admin@your-domain.com


# ─────────────────────────────────────────────────────────────────────────────
# 5. APPLICATION URLS & CORS
# ─────────────────────────────────────────────────────────────────────────────

# FRONTEND_URL — [REQUIRED]
#   The public URL of the Next.js frontend (Vercel domain or custom domain).
#   Used for:
#     • Building email verification and password-reset links
#     • OAuth redirect completion back to the frontend
#   Must be the URL users actually type into their browser.
FRONTEND_URL=https://your-app.vercel.app

# BACKEND_URL — [REQUIRED]
#   The public URL of this FastAPI service (Railway domain or custom domain).
#   Used for OAuth redirect URIs and any backend-generated self-referencing links.
#   Find it in: Railway dashboard → your service → Settings → Networking → Public Domain.
BACKEND_URL=https://repensar-api.up.railway.app

# CORS_ORIGINS — [REQUIRED]
#   JSON array of origins the browser is allowed to send cross-origin requests from.
#   With the Next.js proxy architecture, the browser always calls Vercel, and
#   Vercel proxies server-to-server to Railway. The CORS origin in the browser's
#   request will be your Vercel domain — add it here.
#
#   Rules:
#     • Must include your Vercel deployment domain (and custom domain if any).
#     • Do NOT use a trailing slash.
#     • Must be a valid JSON array string.
#     • "null" origin (e.g. from Electron) should be added explicitly if needed.
#
#   If you have preview deployments on Vercel (e.g. your-app-git-branch-org.vercel.app),
#   add their patterns here or use a wildcard origin carefully.
#
CORS_ORIGINS=["https://your-app.vercel.app"]


# ─────────────────────────────────────────────────────────────────────────────
# 6. NEWSLETTER
# ─────────────────────────────────────────────────────────────────────────────

# NEWSLETTER_FROM_EMAIL — [Optional]
#   "From" address for newsletter campaign emails.
#   Falls back to EMAIL_FROM if not set.
# NEWSLETTER_FROM_EMAIL=newsletter@your-domain.com

# NEWSLETTER_FROM_NAME — [Optional, default: "Repensar Newsletter"]
# NEWSLETTER_FROM_NAME=Repensar Newsletter

# CAMPAIGN_BATCH_SIZE — [Optional, default: 50]
#   Number of emails sent per batch during a campaign. Lower values reduce
#   the risk of hitting SMTP provider rate limits.
# CAMPAIGN_BATCH_SIZE=50

# CAMPAIGN_BATCH_DELAY_SECONDS — [Optional, default: 1.0]
#   Seconds to wait between batches. Tune based on your SMTP provider's limits.
# CAMPAIGN_BATCH_DELAY_SECONDS=1.0

# SUBSCRIPTION_CONFIRM_HOURS — [Optional, default: 24]
#   Hours before a newsletter confirmation link expires.
# SUBSCRIPTION_CONFIRM_HOURS=24


# ─────────────────────────────────────────────────────────────────────────────
# 7. GOOGLE OAUTH
# ─────────────────────────────────────────────────────────────────────────────
#
# Leave all three variables unset to disable Google Sign-In entirely.
# The login/register buttons will be hidden automatically.
#
# Setup:
#   1. https://console.cloud.google.com → create/select a project
#   2. APIs & Services → Credentials → Create → OAuth 2.0 Client ID → Web application
#   3. Add GOOGLE_REDIRECT_URI to "Authorized redirect URIs"
#   4. Copy the Client ID and Client Secret below

# GOOGLE_CLIENT_ID — [Optional]
# GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com

# GOOGLE_CLIENT_SECRET — [Optional]
# GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret

# GOOGLE_REDIRECT_URI — [Optional, required if using Google OAuth]
#   Must point to the backend /auth/google/callback endpoint.
#   Because the Next.js proxy rewrites /auth/:path* → Railway, you can use
#   the Vercel domain (browser-friendly) as the redirect URI, and the
#   proxy will forward it to Railway automatically.
#
#   Option A — via Vercel proxy (recommended):
#     https://your-app.vercel.app/auth/google/callback
#     (add this URL to Google Cloud Console "Authorized redirect URIs")
#
#   Option B — direct Railway domain:
#     https://repensar-api.up.railway.app/auth/google/callback
#     (add this URL to Google Cloud Console "Authorized redirect URIs")
#
# GOOGLE_REDIRECT_URI=https://your-app.vercel.app/auth/google/callback


# ─────────────────────────────────────────────────────────────────────────────
# 8. RATE LIMITING & BRUTE-FORCE PROTECTION
# ─────────────────────────────────────────────────────────────────────────────

# MAX_LOGIN_ATTEMPTS — [Optional, default: 5]
#   Lock an account after this many consecutive failed login attempts.
MAX_LOGIN_ATTEMPTS=5

# LOCKOUT_DURATION_MINUTES — [Optional, default: 30]
#   Minutes an account stays locked before auto-unlocking.
LOCKOUT_DURATION_MINUTES=30

# DISABLE_RATE_LIMITING — [REQUIRED: false in production]
#   Set to true ONLY in development/testing to bypass IP-based rate limits.
#   NEVER enable in production — exposes login, registration, and API endpoints
#   to brute-force and enumeration attacks.
DISABLE_RATE_LIMITING=false


# ─────────────────────────────────────────────────────────────────────────────
# 9. FILE STORAGE
# ─────────────────────────────────────────────────────────────────────────────

# STORAGE_BACKEND — [REQUIRED: "s3" in production]
#   "local" — files saved to UPLOAD_DIR on the server filesystem.
#   "s3"    — files saved to AWS S3 (or S3-compatible storage like Cloudflare R2).
#
#   ⚠️  Railway's filesystem is EPHEMERAL. Every redeploy wipes the container.
#       Any files saved with STORAGE_BACKEND=local will be permanently lost
#       on each deploy. You MUST use "s3" in production.
#
STORAGE_BACKEND=s3

# UPLOAD_DIR — [Optional, default: ./uploads]
#   Only used when STORAGE_BACKEND=local. Ignored when using s3.
# UPLOAD_DIR=./uploads

# MAX_FILE_SIZE — [Optional, default: 10485760 (10 MB)]
#   Maximum allowed upload size in bytes.
# MAX_FILE_SIZE=10485760

# S3_BUCKET — [REQUIRED when STORAGE_BACKEND=s3]
#   The S3 bucket (or Cloudflare R2 bucket) where uploads are stored.
#   Create this bucket before deploying and set the appropriate IAM/R2 permissions.
S3_BUCKET=your-repensar-uploads-bucket

# S3_REGION — [Optional, default: us-east-1]
#   AWS region where the bucket lives. For Cloudflare R2, set to "auto".
S3_REGION=us-east-1

# AWS_ACCESS_KEY_ID — [REQUIRED when STORAGE_BACKEND=s3]
#   IAM access key with s3:PutObject, s3:GetObject, s3:DeleteObject permissions
#   on the S3_BUCKET. For Cloudflare R2, use an R2 API token.
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE

# AWS_SECRET_ACCESS_KEY — [REQUIRED when STORAGE_BACKEND=s3]
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# Cloudflare R2 note:
#   R2 is S3-compatible. Configure your S3 client endpoint to:
#     https://<account-id>.r2.cloudflarestorage.com
#   and set S3_REGION=auto. See app/core/config.py for endpoint configuration.


# ─────────────────────────────────────────────────────────────────────────────
# 10. PRODUCTION FLAGS
# ─────────────────────────────────────────────────────────────────────────────

# DEBUG — [REQUIRED: false in production]
#   Enables:
#     • Verbose exception tracebacks in API responses (leaks internals)
#     • FastAPI's /docs (Swagger UI) and /redoc endpoints
#   NEVER enable in production.
DEBUG=false
